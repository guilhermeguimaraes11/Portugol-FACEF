programa {
  funcao inicio() {
    real centimetros = 2.54 
    real polegadas_digitadas

    escreva("Digite a medida em polegadas: ")
   
    leia(polegadas_digitadas)

  
    real medida = polegadas_digitadas * centimetros

    escreva("A medida de polegadas para centimetros é de: ", medida)
  }
}