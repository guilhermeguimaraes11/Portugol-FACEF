programa {
  funcao inicio() {
    real largura
    real comprimento

    escreva("Digite o largura: ")
    leia(largura)
    escreva("Digite a comprimento: ")
    leia(comprimento)

  real area = (largura * comprimento)
  escreva("\nArea total: ", area)

  real perimetro = 2 * (largura + comprimento)
   escreva("\nPerimetro total: ", perimetro)
  }
}
